{
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(*pfctl -d*)",
      "Bash(*zpool destroy*)",
      "Bash(*docker system prune*)",
      "Bash(*rc.reload_interfaces*)",
      "Edit(credentials/*)",
      "Read(credentials/*)"
    ],
    "allow": [
      "Read(memory/*)",
      "Read(*.md)",
      "Bash(ssh *)",
      "Bash(sshpass *)",
      "Bash(curl *)",
      "Bash(bash */quick-check.sh*)",
      "Bash(su *)",
      "Bash(eval *)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(mountpoint *)",
      "Bash(sudo mount *)",
      "Bash(wc *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/pve-freq/specialists/infra-ops/hooks/preflight.sh"
          }
        ]
      }
    ]
  }
}
