# freq.toml — PVE FREQ Configuration
# Copy this file to freq.toml and customize for your cluster.
# Generated by freq init

[freq]
version = "2.0.0"
brand = "PVE FREQ"
build = "default"          # personality pack: default (neutral) or personal (bass/dubstep)
ascii = false               # true = ASCII box drawing (PuTTY-safe)
debug = false

[ssh]
service_account = "freq-admin"
connect_timeout = 5
max_parallel = 5
mode = "sudo"               # "root" = SSH as root, "sudo" = SSH as service account + sudo
# legacy_password_file = ""  # uncomment for iDRAC/switch password auth

[pve]
# PVE nodes — add your Proxmox host IPs here
nodes = []
node_names = []
ssh_user = "freq-admin"

# Per-node storage configuration (uncomment and edit for each node)
# [pve.storage.node1]
# pool = "local-lvm"
# type = "SSD"

[vm.defaults]
cores = 2
ram = 2048
disk = 32
cpu = "kvm64"
machine = "q35"
scsihw = "virtio-scsi-single"
bios = "ovmf"
domain = "cluster.local"
gateway = ""                # REQUIRED — set to your gateway IP
nameserver = "1.1.1.1"
ci_user = "freq-admin"

[safety]
protected_vmids = []
protected_ranges = [[900, 999]]
max_failure_percent = 50

[infrastructure]
cluster_name = ""
timezone = "UTC"
# truenas_ip = ""
# pfsense_ip = ""
# docker_config_base = ""
# docker_backup_dir = ""

[templates.profiles]
minimal = { cores = 1, ram = 1024, disk = 8 }
standard = { cores = 2, ram = 2048, disk = 32 }
dev = { cores = 4, ram = 4096, disk = 64 }
prod = { cores = 4, ram = 8192, disk = 128 }
docker = { cores = 4, ram = 4096, disk = 64 }

[nic]
bridge = "vmbr0"
mtu = 1500

# NIC profiles — map profile names to VLAN ID lists
# [nic.profiles]
# standard = [100, 200]
# public = [100, 200, 300]
# minimal = [100]

# pfSense integration (uncomment if managing pfSense)
# [pfsense]
# host = ""
# user = "freq-admin"
# config_path = "/cf/conf/config.xml"

[services]
dashboard_port = 8888
watchdog_port = 9900
agent_port = 9990

[notifications]
discord_webhook = ""
slack_webhook = ""
