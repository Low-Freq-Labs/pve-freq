# FREQ Container Registry
# Maps Docker host VMs to their containers for monitoring and management.
#
# Two formats supported:
#
# Format 1 (generated by freq init):
#   [host.<label>]                         — Docker host VM (keyed by label)
#   ip = "10.0.0.50"
#   compose_path = "/opt/stacks"           — base path for compose files
#
#   [host.<label>.containers.<name>]       — individual container
#   port = 8080                            — primary web UI port
#   api_path = "/api/v1/health"            — health check endpoint
#   auth_type = "header"                   — "header", "param", or "cookie"
#   auth_header = "X-Api-Key"              — header name for API auth
#   vault_key = "sonarr_api_key"           — key in FREQ vault for credential
#
# Format 2 (legacy / dashboard-created):
#   [vm.<VMID>]                            — Docker host VM (keyed by PVE VMID)
#   ip = "10.0.0.50"
#   label = "app-server"
#   compose_path = "/opt/stacks"
#
#   [vm.<VMID>.containers.<name>]          — individual container
#   port = 8080
#   api_path = "/api/v1/health"

# Example (host format — recommended):
# [host.arr-stack]
# ip = "10.0.0.31"
# compose_path = "/opt/stacks/arr"
#
# [host.arr-stack.containers.sonarr]
# port = 8989
# api_path = "/api/v3/health"
# auth_type = "header"
# auth_header = "X-Api-Key"
# vault_key = "sonarr_api_key"
#
# [host.arr-stack.containers.radarr]
# port = 7878
# api_path = "/api/v3/health"
# auth_type = "header"
# auth_header = "X-Api-Key"
# vault_key = "radarr_api_key"
